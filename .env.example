# ─────────────────────────────────────────────────────────────────────────────
# Kuro Sōden (黒送伝) — The Dark Relay Pipeline
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram API (shared across all bots) ────────────────────────────────────
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ── Pipeline Bot Tokens (create via @BotFather) ──────────────────────────────
# Lelouch — Request Bot: handles user requests, dedup, admin assignment
REQUEST_BOT_TOKEN=

# Levi — Downloader Bot: source selection, download, processing, thumbnails
DOWNLOADER_BOT_TOKEN=

# Senku — Distribution Bot: channel creation, content generation, stickers
DISTRIBUTION_BOT_TOKEN=

# Gojo — Publisher Bot: main channel, index, caption review, recovery
PUBLISHER_BOT_TOKEN=

# ── Admin Bot Token (shared — used by nekofetch's admin handlers) ────────────
ADMIN_BOT_TOKEN=

# ── Admin / Owner IDs (comma-separated Telegram user IDs) ────────────────────
ADMIN_IDS=0
OWNER_ID=0

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kuro_soden
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kuro_soden

# ── MongoDB ──────────────────────────────────────────────────────────────────
# On Render + MongoDB Atlas M0, add tlsAllowInvalidCertificates=true to the URI
# and whitelist 0.0.0.0/0 (or Render's IPs) in Atlas → Network Access.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=kuro_soden

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PATH=data/storage
SESSION_PATH=data/sessions

# ── TMDB API ─────────────────────────────────────────────────────────────────
TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
AUTO_CREATE_SCHEMA=true
